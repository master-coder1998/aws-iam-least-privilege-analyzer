# AWS Organizations Configuration
org_id         = "o-xxxxxxxxxx"
org_account_id = "123456789012"

# Security Tooling Account (where analyzer is deployed)
security_account_id = "123456789012"

# CloudTrail Lake Configuration
cloudtrail_lake_data_store_id = "arn:aws:cloudtrail:us-east-1:123456789012:eventdatastore/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Notification Configuration
notification_email = "security-team@example.com"

# Optional: Deployment Region
aws_region = "us-east-1"

# Optional: S3 Bucket Prefix
remediation_bucket_prefix = "iam-analyzer-remediation"

# Optional: Minimum Severity for Security Hub
min_severity_for_sechub = "MEDIUM"

# Optional: Cross-Account External ID (generate a UUID)
# cross_account_external_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
